#!/home/pipeline-stable/.conda/envs/pipeline/bin/python

import argparse
import os
import sqlite3
import sys
import signal

from pipeline.const import SCHEDULER_DB_PATH
from pipeline.wrapper import DataReduction


def signal_handler(sig, frame):
    print("\nTerminate process")
    sys.exit(0)


signal.signal(signal.SIGINT, signal_handler)


def _count_existing_schedule_entries(nightdates):
    """Count rows in the scheduler DB whose config filename contains any of the
    given nightdates. Returns a dict {nightdate: count}. Returns an empty dict
    if the DB is not available or no entries are found.
    """
    counts = {nd: 0 for nd in nightdates}
    if not SCHEDULER_DB_PATH or not os.path.exists(SCHEDULER_DB_PATH):
        return counts

    try:
        with sqlite3.connect(SCHEDULER_DB_PATH) as conn:
            cursor = conn.cursor()
            cursor.execute(
                "SELECT name FROM sqlite_master WHERE type='table' AND name='scheduler'"
            )
            if cursor.fetchone() is None:
                return counts

            for nd in nightdates:
                cursor.execute(
                    "SELECT COUNT(*) FROM scheduler WHERE config LIKE ?",
                    (f"%{nd}%",),
                )
                counts[nd] = cursor.fetchone()[0]
    except sqlite3.Error as e:
        print(f"Warning: Could not check existing scheduler entries: {e}")

    return counts


def _prompt_overwrite_schedule(counts):
    """Given a {nightdate: count} dict, warn the user and require explicit
    consent on how to proceed:
        [o] overwrite existing schedule entries (enable --overwrite-schedule)
        [k] keep existing entries and ignore new duplicates (legacy behavior)
        [a] abort the run
    Returns True to enable --overwrite-schedule, False to keep as-is.
    Aborts via sys.exit(0) if the user chooses to abort.
    Non-interactive shells abort with a clear error instead of guessing.
    """
    nonzero = {nd: c for nd, c in counts.items() if c > 0}
    if not nonzero:
        return False

    summary = ", ".join(f"{nd}: {c}" for nd, c in nonzero.items())
    print(f"Warning: scheduler DB already contains entries for ({summary}).")

    if not (sys.stdin.isatty() and sys.stdout.isatty()):
        print(
            "Error: cannot prompt for confirmation (non-interactive shell). "
            "Re-run with --overwrite-schedule to replace them, or remove the "
            "duplicate entries first.",
            file=sys.stderr,
        )
        sys.exit(1)

    while True:
        try:
            answer = input(
                "How to proceed? [o]verwrite / [k]eep existing / [a]bort: "
            ).strip().lower()
        except EOFError:
            print("\nAborted.")
            sys.exit(0)

        if answer in ("o", "overwrite"):
            return True
        if answer in ("k", "keep"):
            return False
        if answer in ("a", "abort", "q", "quit"):
            print("Aborted.")
            sys.exit(0)
        print("Please answer 'o', 'k', or 'a'.")


if __name__ == "__main__":

    parser = argparse.ArgumentParser(
        description="Run data reduction for a given date",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("condition", type=str, help="Condition to run data reduction for")
    parser.add_argument(
        "--priority",
        type=int,
        default=4,
        help="Base priority for scheduled jobs (default: 10)",
    )
    parser.add_argument(
        "--overwrite",
        action="store_true",
        help="Overwrite all outputs (preprocess and science)",
    )
    parser.add_argument(
        "--overwrite-config",
        action="store_true",
        help="Overwrite configs",
    )
    parser.add_argument(
        "--overwrite-data",
        action="store_true",
        help="Overwrite pipeline data outputs (same as --overwrite for from_list)",
    )
    parser.add_argument(
        "--overwrite-preprocess",
        action="store_true",
        help="Overwrite preprocess outputs only",
    )
    parser.add_argument(
        "--overwrite-science",
        action="store_true",
        help="Overwrite science outputs only",
    )
    parser.add_argument(
        "--overwrite-schedule",
        action="store_true",
        help="Overwrite existing schedule in the database",
    )

    args = parser.parse_args()

    if args.condition is None:
        print("Error: Condition is required")
        sys.exit(1)

    args.condition = args.condition.split(",")

    overwrite_schedule = args.overwrite_schedule
    if not overwrite_schedule:
        existing_counts = _count_existing_schedule_entries(args.condition)
        if _prompt_overwrite_schedule(existing_counts):
            overwrite_schedule = True
            print("Proceeding with --overwrite-schedule enabled.")

    try:
        dr = DataReduction(args.condition, use_db=True, is_pipeline=True)
        dr.run(
            use_system_queue=True,
            base_priority=args.priority,
            overwrite=args.overwrite,
            overwrite_config=args.overwrite or args.overwrite_config,
            overwrite_data=args.overwrite or args.overwrite_data,
            overwrite_preprocess=args.overwrite or args.overwrite_data or args.overwrite_preprocess,
            overwrite_science=args.overwrite or args.overwrite_data or args.overwrite_science,
            overwrite_schedule=overwrite_schedule,
        )
    except Exception as e:
        print(f"\nError: {e}")
        sys.exit(1)
