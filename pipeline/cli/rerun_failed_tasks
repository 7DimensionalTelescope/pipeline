#!/home/pipeline-stable/.conda/envs/pipeline/bin/python
"""
Clear Completed Schedules

Script to clear completed schedules from the scheduler database.
Designed to be run periodically via systemd timer.
"""

import sys
from pathlib import Path
import argparse

# Add pipeline to path
pipeline_dir = Path(__file__).parent.parent.parent
sys.path.insert(0, str(pipeline_dir))

from pipeline.services.scheduler import Scheduler
from pipeline.const import SCHEDULER_DB_PATH
from pipeline.services.pipeline_lock import enforce_pipeline_lock


def parse_args():
    parser = argparse.ArgumentParser(description="Rerun failed scheduler tasks.")
    parser.add_argument(
        "--overwrite",
        action="store_true",
        help="If set, rerun failed tasks with overwrite enabled (destructive: may overwrite existing outputs).",
    )
    parser.add_argument(
        "--date",
        type=str,
        default=None,
        help=(
            "Restrict reruns to failed tasks whose config path contains the given date "
            "(e.g. 2025-04-30). Multiple dates may be passed as a comma-separated list. "
            "If omitted, all failed tasks are rerun. Note: this only affects failed entries "
            "already present in the scheduler; if the scheduler has lost or never had configs "
            "for the requested date(s), use run_date instead."
        ),
    )
    return parser.parse_args()


def main():
    """Main entry point."""
    if not SCHEDULER_DB_PATH:
        print("ERROR: SCHEDULER_DB_PATH environment variable not set", file=sys.stderr)
        sys.exit(1)

    try:
        args = parse_args()
        dates = [d.strip() for d in args.date.split(",")] if args.date else None
        dates = [d for d in dates if d] if dates else None

        action_msg = "rerun_failed_tasks is about to requeue failed scheduler entries"
        if dates:
            action_msg += f" for date(s): {', '.join(dates)}"
        action_msg += "."
        enforce_pipeline_lock(action=action_msg, requested_is_pipeline=True)

        scheduler = Scheduler(use_system_queue=True)
        count = scheduler.rerun_failed_tasks(overwrite=bool(args.overwrite), dates=dates)

        scope = f" for date(s): {', '.join(dates)}" if dates else ""
        ow = "with overwrite=True" if args.overwrite else "(overwrite=False)"
        print(f"Successfully requeued {count} failed task(s){scope} {ow}")
        sys.exit(0)
    except Exception as e:
        print(f"ERROR: Failed to rerun failed tasks: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
